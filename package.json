{
  "name": "pivoo-frontend",
  "private": true,
  "packageManager": "npm@10.2.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "web": "turbo run dev --filter=@pivoo/web",
    "mobile": "turbo run dev --filter=@pivoo/mobile"
  },
  "devDependencies": {
    "debug": "^4.4.3",
    "negotiator": "^1.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "caniuse-lite": "^1.0.30001791",
    "lucide-react": "^1.12.0",
    "postcss": "^8.5.12",
    "source-map-js": "^1.2.1",
    "styled-jsx": "^5.1.1"
  }
}
